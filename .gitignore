# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Claude Code local settings (personal permissions/config — do not share)
.claude/

# Project instructions (internal — do not share)
CLAUDE.md

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# EAS credentials (contains keystore password — never commit)
credentials.json

# Google Play service account key — never commit (contains private key)
google-service-account.json
*-service-account*.json

# Firebase app config — device-identifying, keep local per environment
google-services.json
GoogleService-Info.plist

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
